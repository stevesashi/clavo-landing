# Anthropic — required for CV screening AI analysis
# Get key: https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Airtable — required for demo booking form
# 1. Create a base at https://airtable.com
# 2. Add a table "Demo Bookings" with fields:
#    Name (Single line text), Email (Email), Company (Single line text),
#    Selected Dates (Long text), Selected Time (Long text), Created at (Single line text)
# 3. Generate a PAT at https://airtable.com/create/tokens (scope: data.records:write)
# 4. Get Base ID from https://airtable.com/developers/web/api/introduction
AIRTABLE_PAT=your_airtable_personal_access_token
AIRTABLE_BASE_ID=appXXXXXXXXXXXXXX
AIRTABLE_TABLE=Demo Bookings
